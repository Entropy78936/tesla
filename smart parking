package com.project.service;
import com.project.constant.CarType;
import com.project.dto.GetSpotRecommendResDto;
import com.project.dto.ParkingRecordResDto;
import domain.spot.entity.Spot;
import java.util.ArrayList;
import java.util.Comparator;
import java.util.List;
import org.springframework.stereotype.Component;
@Component
public class SpotScheduler {
 public List<GetSpotRecommendResDto>
assignSpots(List<ParkingRecordResDto> records, List<Spot> spots, String
thisCarTypeStr) { CarType thisCarType = CarType.valueOf(thisCarTypeStr.toUpperCase()); List<GetSpotRecommendResDto> results = new ArrayList<>();
 // 1순위: 거리 기반 - 가장 가까운 빈 자리 추천 - 최대 1개
 spots.stream() .filter(s -> !s.getIsFull() && !isAlreadyInResults(results, s)) .findFirst() .ifPresent(s -> results.add(new
GetSpotRecommendResDto(s.getSpotName(), "가장 가까운 빈 자리 (1순위)")));
 // 2순위: 분산 주차 - 양옆이 비어 있는 자리 추천 - 최대 1개
 for (int i = 0; i < spots.size(); i++) { Spot spot = spots.get(i); if (!spot.getIsFull() && isDistributed(spots, i) &&
!isAlreadyInResults(results, spot)) { results.add(new GetSpotRecommendResDto(spot.getSpotName(), " 분산 주차 배치 (2순위)")); break; } }
 // 3순위: 차량 크기 기반 배치 - 최대 1개
 for (int i = 0; i < spots.size(); i++) { Spot spot = spots.get(i); if (!spot.getIsFull() && isGoodSizeMatch(spots, i, thisCarType) &&
!isAlreadyInResults(results, spot)) { results.add(new GetSpotRecommendResDto(spot.getSpotName(),
getReasonByCarType(thisCarType))); break; } }
 return results; }
 private boolean isAlreadyInResults(List<GetSpotRecommendResDto> results,
Spot spot) { return results.stream().anyMatch(r ->
r.spotName().equals(spot.getSpotName())); }
 private boolean isDistributed(List<Spot> spots, int i) { boolean left = i == 0 || !spots.get(i - 1).getIsFull(); boolean right = i == spots.size() - 1 || !spots.get(i + 1).getIsFull(); return left && right; }
 private boolean isGoodSizeMatch(List<Spot> spots, int i, CarType type) { if (type == CarType.COMPACT) { boolean leftLarge = i > 0 && isLarge(spots.get(i - 1)); boolean rightLarge = i < spots.size() - 1 && isLarge(spots.get(i +
1)); return leftLarge && rightLarge; } return true; // MIDSIZE, FULLSIZE, TRUCK 등은 빈 자리면 추천 가능
 }
 private boolean isLarge(Spot s) { return s.getIsFull() && s.getCar() != null && (s.getCar().getCarType() == CarType.FULLSIZE ||
s.getCar().getCarType() == CarType.TRUCK); }
 private String getReasonByCarType(CarType carType) { return switch (carType) { case COMPACT -> "소형차 배치 (3순위)"; case MIDSIZE -> "중형차 배치 (3순위)"; case FULLSIZE, TRUCK -> "대형차/화물차 배치 (3순위)"; }; }
}
